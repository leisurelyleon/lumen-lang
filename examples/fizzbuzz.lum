// FizzBuzz from 1 to 15, using the modulo operator.
var n = 1;
while (n <= 15) {
    if (n % 3 == 0 and n % 5 == 0) {
        print "FizzBuzz";
    } else if (n % 3 == 0) {
        print "Fizz";
    } else if (n % 5 == 0) {
        print "Buzz";
    } else {
        print n;
    }
    n = n + 1;
}
